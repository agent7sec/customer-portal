# Staging Environment Configuration
# These values should be set in AWS Amplify Console Environment Variables
# This file serves as documentation only - do not commit actual values

# Auth0 Configuration (Staging)
VITE_AUTH0_DOMAIN=staging-domain.auth0.com
VITE_AUTH0_CLIENT_ID=staging_client_id
VITE_AUTH0_AUDIENCE=https://api.staging.com

# API Configuration (Staging)
VITE_API_URL=https://api.staging.amazonaws.com/staging

# Stripe Configuration (Staging - Test Keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_staging_key

# Environment
NODE_ENV=staging
