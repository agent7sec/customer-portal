# Production Environment Configuration
# These values should be set in AWS Amplify Console Environment Variables
# This file serves as documentation only - do not commit actual values

# Auth0 Configuration (Production)
VITE_AUTH0_DOMAIN=production-domain.auth0.com
VITE_AUTH0_CLIENT_ID=production_client_id
VITE_AUTH0_AUDIENCE=https://api.production.com

# API Configuration (Production)
VITE_API_URL=https://api.production.amazonaws.com/prod

# Stripe Configuration (Production - Live Keys)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_production_key

# Environment
NODE_ENV=production
